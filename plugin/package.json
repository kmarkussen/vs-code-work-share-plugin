{
  "name": "work-share",
  "displayName": "Work Share",
  "description": "Track and share file activity across team members to improve collaboration",
  "version": "0.0.1",
  "publisher": "your-publisher-name",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "work-share.showFileActivity",
        "title": "Work Share: Show File Activity"
      },
      {
        "command": "work-share.configure",
        "title": "Work Share: Configure Settings"
      }
    ],
    "configuration": {
      "title": "Work Share",
      "properties": {
        "workShare.apiServerUrl": {
          "type": "string",
          "default": "",
          "description": "API server URL for reporting file activity"
        },
        "workShare.userName": {
          "type": "string",
          "default": "",
          "description": "User name for identification (leave empty to use git config)"
        },
        "workShare.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable file activity tracking"
        },
        "workShare.updateInterval": {
          "type": "number",
          "default": 5000,
          "description": "Interval (in milliseconds) for checking file activity"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "work-share",
          "title": "Work Share",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "work-share": [
        {
          "id": "workShareActivity",
          "name": "File Activity"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "18.x",
    "@types/mocha": "^10.0.6",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "glob": "^10.3.10",
    "mocha": "^10.2.0",
    "typescript": "^5.3.2",
    "@vscode/test-electron": "^2.3.8"
  },
  "dependencies": {
    "axios": "^1.6.0"
  }
}
