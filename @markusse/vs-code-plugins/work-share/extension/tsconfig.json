{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "out",
    "lib": [
      "ES2020"
    ],
    "sourceMap": true,
    "inlineSources": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "moduleResolution": "node",
    "types": [
      "node",
      "vscode",
      "mocha"
    ],
    "paths": {
      "@work-share/types": ["../shared/src/index"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    ".vscode-test"
  ]
}
