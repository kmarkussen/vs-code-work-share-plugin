{
  "name": "work-share",
  "displayName": "Work Share",
  "description": "Track and share file activity across team members to improve collaboration",
  "version": "0.0.1",
  "publisher": "your-publisher-name",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/kmarkussen/vs-code-work-share-plugin.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "work-share.showFileActivity",
        "title": "Work Share: Show File Activity"
      },
      {
        "command": "work-share.configure",
        "title": "Work Share: Configure Settings"
      },
      {
        "command": "work-share.toggleTracking",
        "title": "Work Share: Toggle Tracking",
        "icon": "$(eye)"
      },
      {
        "command": "work-share.checkActiveFileConflicts",
        "title": "Work Share: Check Active File Conflicts",
        "icon": "$(warning)"
      },
      {
        "command": "work-share.checkProjectConflicts",
        "title": "Work Share: Check Project Conflicts",
        "icon": "$(repo)"
      },
      {
        "command": "work-share.refreshView",
        "title": "Work Share: Refresh View",
        "icon": "$(refresh)"
      },
      {
        "command": "work-share.openConflictDiff",
        "title": "Work Share: Open Conflict Diff"
      },
      {
        "command": "work-share.syncCurrentRepository",
        "title": "Work Share: Sync Current Repository",
        "icon": "$(sync)"
      },
      {
        "command": "work-share.syncAllRepositories",
        "title": "Work Share: Sync All Known Repositories",
        "icon": "$(repo-sync)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "work-share.toggleTracking",
          "when": "view == workShareActivity && workShare.isTrackingEnabled",
          "group": "navigation@1"
        },
        {
          "command": "work-share.toggleTracking",
          "when": "view == workShareActivity && !workShare.isTrackingEnabled",
          "group": "navigation@1",
          "icon": "$(eye-closed)"
        },
        {
          "command": "work-share.checkActiveFileConflicts",
          "when": "view == workShareActivity",
          "group": "navigation@2"
        },
        {
          "command": "work-share.checkProjectConflicts",
          "when": "view == workShareActivity",
          "group": "navigation@3"
        },
        {
          "command": "work-share.refreshView",
          "when": "view == workShareActivity",
          "group": "navigation@4"
        },
        {
          "command": "work-share.syncCurrentRepository",
          "when": "view == workShareActivity",
          "group": "navigation@5"
        },
        {
          "command": "work-share.syncAllRepositories",
          "when": "view == workShareActivity",
          "group": "navigation@6"
        }
      ]
    },
    "configuration": {
      "title": "Work Share",
      "properties": {
        "workShare.apiServerUrl": {
          "type": "string",
          "default": "",
          "description": "API server URL for reporting file activity"
        },
        "workShare.userName": {
          "type": "string",
          "default": "",
          "description": "User name for identification (leave empty to use git config)"
        },
        "workShare.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable file activity tracking"
        },
        "workShare.updateInterval": {
          "type": "number",
          "default": 5000,
          "description": "Interval (in milliseconds) for checking file activity"
        },
        "workShare.autoCheckConflictsOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically check for incoming patch conflicts whenever a file is saved"
        },
        "workShare.remoteConflictCheckInterval": {
          "type": "number",
          "default": 60000,
          "description": "Interval (in milliseconds) for fetching the remote tracking branch and checking the active file for possible merge conflicts. Set to 0 to disable background remote checks."
        },
        "workShare.gitCommandTimeoutMs": {
          "type": "number",
          "default": 30000,
          "description": "Timeout (in milliseconds) for git CLI commands used by Work Share. Set to a higher value for slow remotes."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "work-share",
          "title": "Work Share",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "work-share": [
        {
          "id": "workShareStatus",
          "name": "Work Share Status"
        },
        {
          "id": "workShareActivity",
          "name": "File Activity"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/extension/src/test/runTest.js",
    "package": "vsce package --no-dependencies",
    "package:prerelease": "vsce package --pre-release --no-dependencies"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^8.54.0",
    "glob": "^10.3.10",
    "mocha": "^10.2.0",
    "typescript": "^5.3.2"
  },
  "dependencies": {}
}
