{
  "name": "work-share-monorepo",
  "version": "1.0.0",
  "description": "Work Share - VS Code extension with API server for team collaboration",
  "private": true,
  "workspaces": {
    "packages": [
      "@markusse/vs-code-plugins/work-share/extension",
      "@markusse/vs-code-plugins/work-share/shared",
      "@markusse/server",
      "@markusse/client"
    ]
  },
  "scripts": {
    "install:all": "npm install",
    "install:extension": "cd @markusse/vs-code-plugins/work-share/extension && npm install",
    "install:server": "cd @markusse/server && npm install",
    "install:client": "cd @markusse/client && npm install",
    "build": "npm run build:shared && npm run build:extension && npm run build:server",
    "build:shared": "cd @markusse/vs-code-plugins/work-share/shared && npm run build",
    "build:extension": "cd @markusse/vs-code-plugins/work-share/extension && npm run compile",
    "build:server": "cd @markusse/server && npm run build",
    "clean": "npm run clean:extension && npm run clean:server",
    "clean:extension": "cd @markusse/vs-code-plugins/work-share/extension && rm -rf out node_modules",
    "clean:server": "cd @markusse/server && rm -rf dist node_modules",
    "clean:client": "cd @markusse/client && rm -rf dist node_modules",
    "dev:extension": "cd @markusse/vs-code-plugins/work-share/extension && npm run watch",
    "dev:server": "cd @markusse/server && npm run dev",
    "dev:client": "cd @markusse/client && npm run dev",
    "test": "npm run test:extension",
    "test:extension": "cd @markusse/vs-code-plugins/work-share/extension && npm test",
    "lint": "npm run lint:extension && npm run lint:server",
    "lint:extension": "cd @markusse/vs-code-plugins/work-share/extension && npm run lint",
    "lint:server": "cd @markusse/server && npm run lint",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f work-share-server",
    "docker:restart": "npm run docker:down && npm run docker:up",
    "start": "docker compose up -d --build",
    "stop": "docker-compose down",
    "try": "npm run try:setup && npm run try:launch",
    "try:setup": "npm run build:extension && npm start && echo 'Waiting for server to start...' && sleep 3",
    "try:launch": "echo '\n✅ Server is running at http://localhost:3000\n✅ Extension is built and ready\n\n📝 Next step: Press F5 in VS Code to launch Extension Development Host\n' && code .",
    "try:stop": "npm stop",
    "package": "bash scripts/package-extension.sh",
    "package:prerelease": "bash scripts/package-extension.sh --pre-release"
  },
  "keywords": [
    "vscode",
    "extension",
    "collaboration",
    "activity-tracking",
    "team-tools"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  }
}
